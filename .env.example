# Copy this file to .env and replace placeholder values:
#   cp .env.example .env
#
# Do not commit .env. It is gitignored.

# Slack bot token from Slack app → OAuth & Permissions → Bot User OAuth Token.
# Required prefix: xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack app-level token from Slack app → Basic Information → App-Level Tokens.
# Must include scope: connections:write
# Required prefix: xapp-
SLACK_APP_TOKEN=xapp-your-app-level-token

# Comma-separated Slack user IDs that can configure Random Coffee from App Home.
# User IDs look like U01234567. Use Slack profile → More → Copy member ID.
ADMIN_USER_IDS=U01234567,U089ABCDE

# SQLite database path.
# Docker compose mounts /data as a persistent volume.
DATABASE_PATH=/data/cafe.sqlite

# Logging level: trace, debug, info, warn, error, fatal, silent
LOG_LEVEL=info

# How often the local scheduler checks due cycles/reminders.
SCHEDULER_INTERVAL_SECONDS=60

# Safety limit: fail a cycle before pairing if eligible users exceed this count.
MAX_PARTICIPANTS=200

# Matching quality knob. Spec requires at least 200 attempts.
MATCH_CANDIDATE_ATTEMPTS=200

# Spec default: each pair receives at most 2 reminders per cycle.
MAX_REMINDERS_PER_MATCH=2

# Calendar-assisted scheduling. Disabled by default; when enabled, matched pairs
# receive scheduling proposals instead of the basic "find a time" notification.
CALENDAR_SCHEDULING_ENABLED=false
CALENDAR_PROVIDER=google
# Google Calendar service-account JSON can be provided inline or by path.
# Use domain-wide delegation / subject when required by your Workspace setup.
GOOGLE_CALENDAR_CREDENTIALS_JSON=
GOOGLE_CALENDAR_CREDENTIALS_PATH=
GOOGLE_CALENDAR_SUBJECT=
CALENDAR_BOT_CALENDAR_ID=primary
CALENDAR_DEFAULT_DURATION_MINUTES=30
CALENDAR_SEARCH_HORIZON_DAYS=7
CALENDAR_MINIMUM_NOTICE_HOURS=24
CALENDAR_DEFAULT_PREFERRED_START=10:00
CALENDAR_DEFAULT_PREFERRED_END=17:00
# What to do if the Pi scheduling agent is unavailable: manual or failed.
CALENDAR_AGENT_FALLBACK_MODE=manual

# Pi scheduling agent. Docker Compose can mount ~/.pi/agent read-only so Cafe can
# reuse your configured Pi credentials. Alternatively set DEEPSEEK_API_KEY.
PI_PROVIDER=deepseek
PI_MODEL=deepseek-v4-flash
PI_AGENT_TIMEOUT_MS=30000
